<?xml version="1.0" ?>
<!--
  thar_desert.sdf - Thar Desert UGV Simulation World
  DEM: output_be_sq.tif (129x129, resampled from 63x134)
  Z range: 42.0 to 93.0 (span 51.0)
  Extent: 1735.3 x 4143.6 m
  Shadow region: 120 vegetation + boundary overlay
  Spawn: (-50.5, -23.2, 56.5)
-->
<sdf version="1.9">
  <world name="thar_desert">

    <!-- 250 Hz frees ~75% CPU vs original 1kHz. Bullet-Featherstone is the
         best articulated-body solver in gz-physics7. -->
    <physics name="250Hz" type="bullet">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
      <bullet>
        <solver><iters>50</iters><sor>1.3</sor></solver>
        <constraints>
          <cfm>0.0</cfm><erp>0.2</erp>
          <contact_surface_layer>0.001</contact_surface_layer>
          <split_impulse>true</split_impulse>
          <split_impulse_penetration_threshold>-0.001</split_impulse_penetration_threshold>
        </constraints>
      </bullet>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu">
      <initial_orientation_as_reference>true</initial_orientation_as_reference>
    </plugin>
    <plugin filename="gz-sim-navsat-system" name="gz::sim::systems::NavSat"/>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 500 0 0 0</pose>
      <diffuse>1.0 0.96 0.88 1</diffuse>
      <specular>0.9 0.85 0.75 1</specular>
      <attenuation><range>10000</range><constant>0.9</constant><linear>0</linear><quadratic>0</quadratic></attenuation>
      <direction>-0.3 0.2 -0.93</direction>
      <intensity>1.5</intensity>
    </light>
    <light type="directional" name="fill_light">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 500 0 0 0</pose>
      <diffuse>0.35 0.32 0.28 1</diffuse>
      <specular>0.15 0.12 0.08 1</specular>
      <attenuation><range>10000</range><constant>0.9</constant><linear>0</linear><quadratic>0</quadratic></attenuation>
      <direction>0.4 -0.3 -0.5</direction>
    </light>

    <scene>
      <ambient>0.55 0.52 0.45 1</ambient>
      <background>0.72 0.78 0.88 1</background>
      <shadows>true</shadows>
      <grid>false</grid>
      <origin_visual>false</origin_visual>
      <sky>
        <time>10</time>
        <sunrise>5.5</sunrise>
        <sunset>19.5</sunset>
        <clouds><speed>6</speed><mean_size>0.3</mean_size><ambient>0.9 0.9 0.9 1</ambient></clouds>
      </sky>
    </scene>

    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <latitude_deg>27.0318056</latitude_deg>
      <longitude_deg>69.5280556</longitude_deg>
      <elevation>42</elevation>
      <heading_deg>0</heading_deg>
    </spherical_coordinates>

    <!-- TEMPORARY: neon marker pole at robot spawn position (-50.5, -23.2) -->
    <model name="spawn_marker">
      <static>true</static>
      <pose>-50.5 -23.2 18.0 0 0 0</pose>
      <link name="marker_link">
        <visual name="pole">
          <pose>0 0 100 0 0 0</pose>
          <geometry>
            <cylinder><radius>1.5</radius><length>200.0</length></cylinder>
          </geometry>
          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
            <specular>1 0.3 0.3 1</specular>
            <emissive>0.8 0 0 1</emissive>
          </material>
        </visual>
        <visual name="ball">
          <pose>0 0 210 0 0 0</pose>
          <geometry>
            <sphere><radius>15</radius></sphere>
          </geometry>
          <material>
            <ambient>1 1 0 1</ambient>
            <diffuse>1 1 0 1</diffuse>
            <specular>1 1 0.3 1</specular>
            <emissive>0.8 0.8 0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- Terrain heightmap -->
    <model name="terrain">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="terrain_link">
        <collision name="terrain_collision">
          <geometry>
            <heightmap>
              <uri>file://worlds/dem/output_be_sq.tif</uri>
              <size>1735.3 4143.6 51.0</size>
              <pos>0 0 0</pos>
              <sampling>4</sampling>
            </heightmap>
          </geometry>
          <surface>
            <!-- STIFF terrain - follows DEM exactly, zero penetration.
                 Sand behavior comes from wheel friction/slip, not terrain softness. -->
            <friction><ode><mu>0.4</mu><mu2>0.3</mu2></ode></friction>
            <contact>
              <ode>
                <kp>1e8</kp>
                <kd>1000</kd>
                <min_depth>0</min_depth>
                <max_vel>0.01</max_vel>
              </ode>
            </contact>
          </surface>
        </collision>
        <visual name="terrain_visual">
          <geometry>
            <heightmap>
              <uri>file://worlds/dem/output_be_sq.tif</uri>
              <size>1735.3 4143.6 51.0</size>
              <pos>0 0 0</pos>
              <texture>
                <diffuse>file://worlds/textures/sand_flat.jpg</diffuse>
                <normal>file://worlds/textures/sand_flat_normal.jpg</normal>
                <size>8</size>
              </texture>
              <texture>
                <diffuse>file://worlds/textures/sand_dune.jpg</diffuse>
                <normal>file://worlds/textures/sand_dune_normal.jpg</normal>
                <size>8</size>
              </texture>
              <texture>
                <diffuse>file://worlds/textures/gravel_hard.jpg</diffuse>
                <normal>file://worlds/textures/gravel_hard_normal.jpg</normal>
                <size>8</size>
              </texture>
              <blend><min_height>15</min_height><fade_dist>5</fade_dist></blend>
              <blend><min_height>35</min_height><fade_dist>5</fade_dist></blend>
            </heightmap>
          </geometry>
        </visual>
      </link>
    </model>


