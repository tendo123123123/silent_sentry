    <name>bush-6_0002</name>
    <pose>-421.396 -121.891 12.713 0 0 3.175241</pose>
  </include>

  <include>
    <uri>model://long-bush-3</uri>
    <name>long-bush-3_0003</name>
    <pose>-426.118 -90.349 12.879 0 0 1.385069</pose>
  </include>

  <include>
    <uri>model://boulder-1</uri>
    <name>boulder-1_0004</name>
    <pose>80.339 92.829 8.784 0 0 4.767727</pose>
  </include>

</world>
</sdf>