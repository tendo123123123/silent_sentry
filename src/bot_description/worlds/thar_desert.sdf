<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="thar_desert">

    <physics name="250Hz" type="bullet">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
      <bullet>
        <solver><iters>50</iters><sor>1.3</sor></solver>
        <constraints>
          <cfm>0.0</cfm><erp>0.2</erp>
          <contact_surface_layer>0.001</contact_surface_layer>
          <split_impulse>true</split_impulse>
          <split_impulse_penetration_threshold>-0.001</split_impulse_penetration_threshold>
        </constraints>
      </bullet>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu">
      <initial_orientation_as_reference>true</initial_orientation_as_reference>
    </plugin>
    <plugin filename="gz-sim-navsat-system" name="gz::sim::systems::NavSat"/>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0.00 0.00 20.0 0 0 0</pose>
      <diffuse>0.90 0.85 0.75 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>10000</range>
        <constant>0.9</constant>
        <linear>0</linear>
        <quadratic>0</quadratic>
      </attenuation>
      <direction>-0.6 0.5 -0.62</direction>
      <intensity>1.0</intensity>
    </light>
    <light type="directional" name="fill_light">
      <cast_shadows>false</cast_shadows>
      <pose>0.00 0.00 11.435 0 0 0</pose>
      <diffuse>0.35 0.32 0.28 1</diffuse>
      <specular>0.15 0.12 0.08 1</specular>
      <attenuation><range>10000</range><constant>0.9</constant><linear>0</linear><quadratic>0</quadratic></attenuation>
      <direction>0.4 -0.3 -0.5</direction>
    </light>

    <scene>
      <ambient>0.55 0.52 0.45 1</ambient>
      <background>0.72 0.78 0.88 1</background>
      <shadows>true</shadows>
      <grid>false</grid>
      <origin_visual>false</origin_visual>
      <sky>
        <time>10</time>
        <sunrise>5.5</sunrise>
        <sunset>19.5</sunset>
        <clouds><speed>6</speed><mean_size>0.3</mean_size><ambient>0.9 0.9 0.9 1</ambient></clouds>
      </sky>
    </scene>

    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <latitude_deg>27.0318056</latitude_deg>
      <longitude_deg>69.5280556</longitude_deg>
      <elevation>42</elevation>
      <heading_deg>0</heading_deg>
    </spherical_coordinates>

    <model name="terrain">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="terrain_link">
        
        <collision name="terrain_collision">
          <geometry>
            <heightmap>
              <uri>file://worlds/dem/physics_ready_dem.tif</uri>
              <size>900.0 300.0 25.0</size>
              <pos>0 0 0 0 0 0</pos>
              <sampling>2</sampling>
            </heightmap>
          </geometry>
        </collision>
        
        <visual name="terrain_visual">
          <geometry>
            <heightmap>
              <uri>file://worlds/dem/physics_ready_dem.tif</uri>
              <size>900.0 300.0 25.0</size>
              <pos>0 0 0 0 0 0</pos>
              <sampling>2</sampling>
              <texture>
                <diffuse>file://worlds/textures/sandy_gravel_02_diff_2k.jpg</diffuse>
                <normal>file://worlds/textures/sandy_gravel_02_nor_gl_2k.jpg</normal>
                <size>10</size>
              </texture>
            </heightmap>
          </geometry>
        </visual>
        
      </link>
    </model>

































































































































































































































































































































































































































































































































































































































































































































































































































  <include>
