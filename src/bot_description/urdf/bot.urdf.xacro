<?xml version="1.0"?>
<robot name="autobot" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:include filename="bot_ros2_control.xacro"/>

  <!-- Base Footprint (reference frame) -->
  <link name="base_footprint"/>

  <!-- Main Base Link -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5"/>
      <inertia ixx="0.144" ixy="0" ixz="0" iyy="0.857" iyz="0" izz="0.840"/>
    </inertial>

    <collision name="base_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.37 0.37 0.415"/>
      </geometry>
      <surface>
        <contact>
          <collide_without_contact>false</collide_without_contact>
          <ode>
            <min_depth>0.005</min_depth>
            <kp>1e6</kp>
            <kd>100.0</kd>
            <max_vel>0.01</max_vel>
          </ode>
        </contact>
        <friction>
          <ode>
            <mu>0.5</mu>
            <mu2>0.4</mu2>
          </ode>
        </friction>
      </surface>
    </collision>

    <visual name="base_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box  size="1.37 0.37 0.415"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.8 1"/>
      </material>
    </visual>

  </link>

  <!-- Fixed joint between base_footprint and base_link -->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.175" rpy="0 0 0"/>
  </joint>


 <link name="base_front_left_steering">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.25"/>
      <inertia ixx="0.000633" ixy="0" ixz="0" iyy="0.000633" iyz="0" izz="0.00125"/>
    </inertial>

    <visual name="base_front_left_steering_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.02"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>

    <collision name="base_front_left_steering_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_front_left_steering_joint" type="revolute">
    <parent link="base_link"/>
    <child link="base_front_left_steering"/>
    <origin xyz="0.39 -0.265 -0.2075" rpy="-1.57079632679 0 0"/>
    <limit lower="-0.2616" upper="0.2616" effort="100" velocity="1.0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="base_front_right_steering">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.25"/>
      <inertia ixx="0.000633" ixy="0" ixz="0" iyy="0.000633" iyz="0" izz="0.00125"/>
    </inertial>

    <visual name="base_front_right_steering_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.02"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>

    <collision name="base_front_right_steering_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_front_right_steering_joint" type="revolute">
    <parent link="base_link"/>
    <child link="base_front_right_steering"/>
    <origin xyz="0.39 0.265 -0.2075" rpy="-1.57079632679 0 0"/>
    <limit lower="-0.2616" upper="0.2616" effort="100" velocity="1.0"/>
    <axis xyz="0 1 0"/>
  </joint>
  
  <!-- ========== FRONT LEFTWHEEL ========== -->

  <link name="base_front_left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.0181" ixy="0" ixz="0" iyy="0.0306" iyz="0" izz="0.0306"/>
    </inertial>

    <visual name="base_front_left_wheel_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.175" length="0.13"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>

    <collision name="base_front_left_wheel_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.175" length="0.13"/>
      </geometry>
      <surface>
        <!-- Stiff wheel on stiff ground. Sand effect via friction/slip only -->
        <contact>
          <collide_without_contact>false</collide_without_contact>
          <ode>
            <min_depth>0</min_depth>
            <kp>1e6</kp>
            <kd>200.0</kd>
            <max_vel>0.01</max_vel>
          </ode>
        </contact>
        <friction>
          <ode>
            <mu>0.4</mu>
            <mu2>0.3</mu2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>

  <joint name="base_front_left_wheel_joint" type="continuous">
    <parent link="base_front_left_steering"/>
    <child link="base_front_left_wheel"/>
    <origin xyz="0 0 -0.075" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

    <!-- ========== FRONT RIGHTWHEEL ========== -->
  

  <link name="base_front_right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy=" 0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.0181" ixy="0" ixz="0" iyy="0.0306" iyz="0" izz="0.0306"/>
    </inertial>

    <visual name="base_front_right_wheel_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.175" length="0.13"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>

    <collision name="base_front_right_wheel_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.175" length="0.13"/>
      </geometry>
      <surface>
        <!-- Stiff wheel on stiff ground. Sand effect via friction/slip only -->
        <contact>
          <collide_without_contact>false</collide_without_contact>
          <ode>
            <min_depth>0</min_depth>
            <kp>1e6</kp>
            <kd>200.0</kd>
            <max_vel>0.01</max_vel>
          </ode>
        </contact>
        <friction>
          <ode>
            <mu>0.4</mu>
            <mu2>0.3</mu2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>

  <joint name="base_front_right_wheel_joint" type="continuous">
    <parent link="base_front_right_steering"/>
    <child link="base_front_right_wheel"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ========== BACK LEFTWHEEL ========== -->
  

  <link name="base_back_left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.0181" ixy="0" ixz="0" iyy="0.0306" iyz="0" izz="0.0306"/>
    </inertial>

    <visual name="base_back_left_wheel_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.175" length="0.13"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>

    <collision name="base_back_left_wheel_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.175" length="0.13"/>
      </geometry>
      <surface>
        <!-- Stiff wheel on stiff ground. Sand effect via friction/slip only -->
        <contact>
          <collide_without_contact>false</collide_without_contact>
          <ode>
            <min_depth>0</min_depth>
            <kp>1e6</kp>
            <kd>200.0</kd>
            <max_vel>0.01</max_vel>
          </ode>
        </contact>
        <friction>
          <ode>
            <mu>0.4</mu>
            <mu2>0.3</mu2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>

  <joint name="base_back_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="base_back_left_wheel"/>
    <origin xyz="-0.51 -0.335 -0.2075" rpy="-1.57079632679 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

    <!-- ========== BACK RIGHTWHEEL ========== -->
  

  <link name="base_back_right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.0181" ixy="0" ixz="0" iyy="0.0306" iyz="0" izz="0.0306"/>
    </inertial>

    <visual name="base_back_right_wheel_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.175" length="0.13"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>

    <collision name="base_back_right_wheel_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.175" length="0.13"/>
      </geometry>
      <surface>
        <!-- Stiff wheel on stiff ground. Sand effect via friction/slip only -->
        <contact>
          <collide_without_contact>false</collide_without_contact>
          <ode>
            <min_depth>0</min_depth>
            <kp>1e6</kp>
            <kd>200.0</kd>
            <max_vel>0.01</max_vel>
          </ode>
        </contact>
        <friction>
          <ode>
            <mu>0.4</mu>
            <mu2>0.3</mu2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>

  <joint name="base_back_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="base_back_right_wheel"/>
    <origin xyz="-0.51 0.335 -0.2075" rpy="-1.57079632679 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>


 
<!-- ============================================ -->

  <link name="bot_storage_base">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.3132" ixy="0" ixz="0" iyy="0.1071" iyz="0" izz="0.4195"/>
    </inertial>

    <collision name="bot_storage_base_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.8 1.37 0.05"/>
      </geometry>
    </collision>

    <visual name="bot_storage_base_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box  size="0.8 1.37 0.05"/>
      </geometry>
      <material name="rgb">
        <color rgba="0.4 0.9 0.5 1"/>
      </material>
    </visual>
  </link>


  <joint name="bot_storage_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="bot_storage_base"/>
    <origin xyz="0 0 0.2325" rpy="0 0 1.57079632679"/>
  </joint>
<!-- ============================================ -->
   <link name="rgb_camera">
    <inertial>
    <origin xyz="-0.03 0 0" rpy="0 0 0"/>
        <mass value="0.1" />
        <inertia ixx="0.000023" ixy="0.0" ixz="0"
            iyy="0.000011" iyz="0" izz="0.000030" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.57079632679" />
      <geometry>
         <mesh filename="file://$(find bot_description)/meshes/3dCamera.DAE" scale="1 1 1"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
          <box size="0.03 0.05 0.02" />
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="0.685 0 0.15" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="rgb_camera"/>
    <axis xyz="0.0 0 0"/>
  </joint>

  <joint type="fixed" name="camera_optical_joint">
    <origin xyz="0 0 0.151" rpy="0 0 0"/>
    <parent link="rgb_camera"/>
    <child link="camera_link_optical"/>
  </joint> 

   <link name="camera_link_optical">
  </link>

    <gazebo reference="camera_link_optical">
    <sensor name="camera" type="camera">
      <camera>
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>15</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
        <optical_frame_id>camera_link_optical</optical_frame_id>
        <camera_info_topic>camera/camera_info</camera_info_topic>
      </camera>
      <always_on>1</always_on>
      <update_rate>10</update_rate>
      <visualize>true</visualize>
      <topic>camera/image_raw</topic>
    </sensor>
    </gazebo>

 
  <link name="laser_link">
    <!-- <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.3" />
            <inertia ixx="0.000458" ixy="0.0" ixz="0"
            iyy="0.000458" iyz="0" izz="0.000399" />
    </inertial> -->

    <visual>
      <geometry>
        <mesh filename="file://$(find bot_description)/meshes/lidar_3d_v1.dae" scale="1 1 1"/>
      </geometry>
    </visual>

    <collision>

      <geometry>
        <cylinder radius="0.0516" length="0.0717" />
      </geometry>
    </collision>
  </link>

  <!-- LiDAR mounting mast visual-only support column from chassis top (z=0.2075) to lidar_base bottom (z=0.634). -->
  <!-- Mast length = 0.426 m, radius = 20 mm (40 mm dia section steel tube), two 80x80x8 mm flanges. -->
  <link name="lidar_mast">
    <visual name="lidar_mast_pole">
      <origin xyz="0 0 0.213" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.020" length="0.426"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.20 0.20 0.20 1"/>
      </material>
    </visual>
    <visual name="lidar_mast_flange_bottom">
      <origin xyz="0 0 0.004" rpy="0 0 0"/>
      <geometry>
        <box size="0.080 0.080 0.008"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.20 0.20 0.20 1"/>
      </material>
    </visual>
    <visual name="lidar_mast_flange_top">
      <origin xyz="0 0 0.422" rpy="0 0 0"/>
      <geometry>
        <box size="0.080 0.080 0.008"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.20 0.20 0.20 1"/>
      </material>
    </visual>
  </link>

  <joint name="lidar_mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_mast"/>
    <!-- Mast base flush with chassis top surface (z = half chassis height = 0.2075 m from base_link origin) -->
    <origin xyz="0.60 0 0.2075" rpy="0 0 0"/>
  </joint>

  <link name="lidar_base">
    <!-- <inertial>
      <origin xyz="0 0 0.011" rpy="0 0 0"/>
      <mass value="0.2" />
      <inertia ixx="0.000043" ixy="0.0" ixz="0"
          iyy="0.000043" iyz="0" izz="0.000266" />
    </inertial> -->

    <visual>
    <origin xyz="0 0 0.011" rpy="0 0 0"/>
        <material name="black">
        <color rgba="0.15 0.15 0.15 1"/>
      </material>
      <geometry>
        <cylinder radius="0.0516" length="0.032" />
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0.011" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0516" length="0.032" />
      </geometry>
    </collision>
  </link>

    <joint name="lidar_base_joint" type="fixed">
    <origin xyz="0 0 0.431" rpy="0 0 0"/>
    <parent link="lidar_mast"/>
    <child link="lidar_base"/>
    <axis xyz="0.0 0.0 1.0"/>
  </joint>

  <joint name="laser_joint" type="fixed">
    <origin xyz="0 0 0.027" rpy="0 0.0 0.0"/>
    <parent link="lidar_base"/>
    <child link="laser_link"/>
    <axis xyz="0.0 0.0 1.0"/>
  </joint>

  <gazebo reference="laser_link">
    <sensor name="lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <gz_frame_id>laser_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>900</samples>
            <resolution>1.00000</resolution>
            <min_angle>0.000000</min_angle>
            <max_angle>6.283185</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1.0</resolution>
            <min_angle>-0.959931</min_angle>
            <max_angle>0.261799</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.20</min>
          <max>150.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo> 


  <joint name="navsat_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link"/>
    <child link="navsat_link" />
  </joint>

  <link name="navsat_link">
  </link>

  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="lidar_base"/>
    <child link="imu_link" />
  </joint>

  <link name="imu_link">
  </link>

  <gazebo reference="imu_link">
    <sensor name="imu" type="imu">
      <always_on>true</always_on>
      <update_rate>400</update_rate>  <!-- 400 Hz for LIO-SAM odometry sync -->
      <visualize>true</visualize>
      <topic>/imu</topic>         <!-- Standard IMU topic -->
      <enable_metrics>true</enable_metrics>
      <gz_frame_id>imu_link</gz_frame_id>
      
      <!-- Enhanced IMU parameters for accurate sensing -->
      <imu>
        <angular_velocity>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <gazebo reference="navsat_link">
    <sensor name="navsat" type="navsat">
      <always_on>1</always_on>
      <update_rate>1</update_rate>
      <topic>navsat</topic>
      <gz_frame_id>navsat_link</gz_frame_id>
    </sensor>
  </gazebo> 

  <!-- =================================================================
       BEKKER-WONG TERRAMECHANICS - Thar Desert Dry Aeolian Sand
       =================================================================
       Reference soil parameters (Wong 2001, Iagnemma and Dubowsky 2004)
         k_c   = 0.99    kN/m^(n+1)   cohesive modulus of deformation
         k_phi = 1528.43 kN/m^(n+2)   frictional modulus of deformation
         n     = 1.1                    sinkage exponent
         c     = 1.04    kPa           soil cohesion
         phi   = 28      deg           internal friction angle
         K     = 0.025   m             Janosi-Hanamoto shear deformation modulus

       Robot total mass  = 16.1 kg  (158 N)
       CG offset x       = -0.015 m  (near-centred, slight rear bias)
       Wheelbase          = 0.90  m   (front axle +0.39, rear -0.51)
       Front wheel load   = 43 N each (static)
       Rear  wheel load   = 36 N each (static)
       Wheel radius       = 0.175 m,  width = 0.13 m

       Bekker sinkage z0  = 0.4 mm  (negligible for 16 kg robot)
       Contact patch L    = 12 mm
       Janosi-Hanamoto traction efficiency at slip ratios
         20 pct slip  =  9 pct of maximum traction
         50 pct slip  = 21 pct of maximum traction
        100 pct slip  = 38 pct of maximum traction
       (Poor saturation because contact patch L << K)

       Coulomb mu  = tan(28 deg) = 0.53 scaled to 0.4 for loose surface
       Lateral mu2 = 0.3 (75 pct of mu, anisotropic sand)
       Base slip1/slip2 approximate Bekker rolling resistance
       WheelSlip compliance approximates Janosi-Hanamoto traction curve
       =================================================================  -->
  <!-- Front wheels  Bekker-Wong base slip from rolling-resistance equivalent -->
  <gazebo reference="base_front_left_wheel">
    <mu1>0.8</mu1>
    <mu2>0.5</mu2>
    <kp>1e6</kp>
    <kd>200.0</kd>
    <slip1>0.12</slip1>
    <slip2>0.15</slip2>
    <minDepth>0.005</minDepth>
    <maxVel>0.01</maxVel>
    <fdir1>1 0 0</fdir1>
  </gazebo>

  <gazebo reference="base_front_right_wheel">
    <mu1>0.8</mu1>
    <mu2>0.5</mu2>
    <kp>1e6</kp>
    <kd>200.0</kd>
    <slip1>0.12</slip1>
    <slip2>0.15</slip2>
    <minDepth>0.005</minDepth>
    <maxVel>0.01</maxVel>
    <fdir1>1 0 0</fdir1>
  </gazebo>

  <!-- Rear drive wheels  higher base slip, lighter static load (36 N each) -->
  <gazebo reference="base_back_left_wheel">
    <mu1>0.8</mu1>
    <mu2>0.5</mu2>
    <kp>1e6</kp>
    <kd>200.0</kd>
    <slip1>0.14</slip1>
    <slip2>0.12</slip2>
    <minDepth>0.005</minDepth>
    <maxVel>0.01</maxVel>
    <fdir1>1 0 0</fdir1>
  </gazebo>

  <gazebo reference="base_back_right_wheel">
    <mu1>0.8</mu1>
    <mu2>0.5</mu2>
    <kp>1e6</kp>
    <kd>200.0</kd>
    <slip1>0.14</slip1>
    <slip2>0.12</slip2>
    <minDepth>0.005</minDepth>
    <maxVel>0.01</maxVel>
    <fdir1>1 0 0</fdir1>
  </gazebo>

  <!-- Chassis soft contact -->
  <gazebo reference="base_link">
    <kp>1e6</kp>
    <kd>100.0</kd>
    <mu1>0.5</mu1>
    <mu2>0.4</mu2>
    <minDepth>0.005</minDepth>
    <maxVel>0.01</maxVel>
  </gazebo>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find bot_controller)/config/bot_controller.yaml</parameters>
      <hold_joints_at_controller_startup>false</hold_joints_at_controller_startup>
    </plugin>
    <!-- Sensors, Imu, NavSat system plugins are in the world SDF — do NOT duplicate here -->

    <!-- WheelSlip plugin  Bekker-Wong / Janosi-Hanamoto SOTA
         (ROSCon wheel-slip terramechanics approximation)

         Slip compliance is force-normalised.  At nominal load the
         additional ODE slip = compliance value.  When the wheel
         unloads (bumps, accel, braking) slip rises inversely with
         contact force, matching Bekker-Wong load-dependent traction.

         Longitudinal compliance derived from Janosi-Hanamoto curve
           K = 0.025 m with contact-patch 12 mm means traction
           saturates very slowly.  Compliance 0.6-0.7 captures the
           high slip-ratio needed for desert sand grip.
         Lateral compliance from sand low lateral shear resistance
           (cohesion c = 1.04 kPa, poor plowing resistance).
         wheel_normal_force corrected to actual CG-based static load.  -->
    <plugin filename="gz-sim-wheel-slip-system" name="gz::sim::systems::WheelSlip">
      <wheel link_name="base_front_left_wheel">
        <slip_compliance_lateral>0.15</slip_compliance_lateral>
        <slip_compliance_longitudinal>0.1</slip_compliance_longitudinal>
        <wheel_normal_force>43</wheel_normal_force>
        <wheel_radius>0.175</wheel_radius>
      </wheel>
      <wheel link_name="base_front_right_wheel">
        <slip_compliance_lateral>0.15</slip_compliance_lateral>
        <slip_compliance_longitudinal>0.1</slip_compliance_longitudinal>
        <wheel_normal_force>43</wheel_normal_force>
        <wheel_radius>0.175</wheel_radius>
      </wheel>
      <wheel link_name="base_back_left_wheel">
        <slip_compliance_lateral>0.15</slip_compliance_lateral>
        <slip_compliance_longitudinal>0.1</slip_compliance_longitudinal>
        <wheel_normal_force>36</wheel_normal_force>
        <wheel_radius>0.175</wheel_radius>
      </wheel>
      <wheel link_name="base_back_right_wheel">
        <slip_compliance_lateral>0.15</slip_compliance_lateral>
        <slip_compliance_longitudinal>0.1</slip_compliance_longitudinal>
        <wheel_normal_force>36</wheel_normal_force>
        <wheel_radius>0.175</wheel_radius>
      </wheel>
    </plugin>

    <!-- LookupWheelSlip not available in Gazebo Sim 8 (Harmonic), needs gz-sim 10+.
         The slip_map.png is ready at models/terrain/materials/textures/slip_map.png -->

  </gazebo>

</robot>
